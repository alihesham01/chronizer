{
  "name": "chronizer",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "swc src --out-dir dist --strip-leading-paths",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "db:setup": "tsx scripts/setup-db.ts",
    "test": "echo \"Tests not implemented yet\" && exit 0",
    "lint": "echo \"Linting not implemented yet\" && exit 0",
    "docker:build": "docker build --no-cache -t chronizer-backend .",
    "docker:run": "docker-compose up -d",
    "docker:logs": "docker-compose logs -f",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.5",
    "@hono/zod-validator": "^0.7.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.1",
    "dotenv": "^17.3.1",
    "hono": "^4.6.7",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pg": "^8.18.0",
    "puppeteer": "^23.10.4",
    "tsx": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.17.6",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.7.2"
  }
}
